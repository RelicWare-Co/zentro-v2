# --- Database (PostgreSQL with logical replication for Zero) ---
# Bring up via `docker compose up -d` (Postgres + zero-cache in ./docker-compose.yml).
DATABASE_URL="postgresql://zentro:zentro@localhost:5432/zentro"

# --- Zero (Rocicorp) ---
# Zero replicates from this Postgres into its local SQLite replica via logical replication.
# Must point to the same DB as DATABASE_URL during dev.
ZERO_UPSTREAM_DB="postgresql://zentro:zentro@localhost:5432/zentro"

# Public URL of zero-cache exposed to the browser. The server passes this to the
# client via Vike pageContext at runtime.
VITE_ZERO_CACHE_URL="http://localhost:4848"
# Optional non-Vite alias for runtime-only deploy environments.
ZERO_CACHE_URL="http://localhost:4848"

# Authoritative endpoints zero-cache calls on the app server.
# Used by `zero-cache-dev` (bun run zero:dev) — must match the running app port.
ZERO_QUERY_URL="http://localhost:3000/api/zero/query"
ZERO_MUTATE_URL="http://localhost:3000/api/zero/mutate"

# Forward better-auth cookies from the browser websocket request through
# zero-cache to /api/zero/* so the server can derive ZeroContext.
ZERO_QUERY_FORWARD_COOKIES=true
ZERO_MUTATE_FORWARD_COOKIES=true

# Required for production zero-cache (rocicorp/zero Docker image).
# Not needed for local `bun run zero:dev`.
ZERO_ADMIN_PASSWORD="change-me-in-production"

# --- Better Auth ---
BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="change-me-in-real-deployments"

# Production only: required when the app and zero-cache live on sibling
# subdomains, e.g. app.example.com and zero.example.com.
BETTER_AUTH_COOKIE_DOMAIN="example.com"
BETTER_AUTH_TRUSTED_ORIGINS="https://app.example.com,https://zero.example.com"

# --- QZ Tray silent printing (optional) ---
# Server-side signing so operators print without QZ's "allow request" popup.
# Generate the pair with `qz/generate-certs.ps1` (or .sh), then point these at
# the files (or paste the PEM contents inline). When unset, QZ falls back to
# its unsigned mode (printing still works, but shows the popup).
# QZ_CERTIFICATE_PATH="./qz/certs/digital-certificate.txt"
# QZ_PRIVATE_KEY_PATH="./qz/certs/private-key.pem"
# QZ_PRIVATE_KEY_PASSPHRASE=""
# Inline alternatives (take precedence over the *_PATH vars):
# QZ_CERTIFICATE="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# QZ_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# --- Playwright E2E (optional; export before `bun run e2e:playwright`) ---
# PLAYWRIGHT_BASE_URL="http://localhost:3000"
# PLAYWRIGHT_LOGIN_EMAIL=""
# PLAYWRIGHT_LOGIN_PASSWORD=""
# PLAYWRIGHT_ORG_NAME=""
# PLAYWRIGHT_NEW_ORG_NAME="Playwright Test Store"
# PLAYWRIGHT_REGISTER_NAME="Playwright E2E"
# PLAYWRIGHT_REGISTER_EMAIL=""
# PLAYWRIGHT_REGISTER_PASSWORD=""
