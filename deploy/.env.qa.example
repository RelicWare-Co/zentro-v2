# Copy to deploy/.env.qa and pass `--env-file deploy/.env.qa` for plain
# `docker compose` QA deploys.
# On Coolify, set these in the QA resource Environment Variables UI instead.
# Do not commit deploy/.env.qa.

# --- Dedicated QA Postgres ---
POSTGRES_USER=zentro
POSTGRES_PASSWORD=replace-with-a-strong-qa-db-password
POSTGRES_DB=zentro_qa

# Internal QA database URL. Keep this pointed at the compose `postgres` service
# unless you intentionally move QA to an external database.
DATABASE_URL=postgresql://zentro:replace-with-a-strong-qa-db-password@postgres:5432/zentro_qa

# --- App / auth (public browser-facing QA URLs) ---
# Coolify: assign domains to app:3000 and zero-cache:4848, then set e.g.
#   BETTER_AUTH_URL=${SERVICE_URL_APP_3000}
#   ZERO_CACHE_URL=${SERVICE_URL_ZERO-CACHE_4848}
#   BETTER_AUTH_TRUSTED_ORIGINS=${SERVICE_URL_APP_3000},${SERVICE_URL_ZERO-CACHE_4848}
BETTER_AUTH_URL=https://app.qa.example.com
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_COOKIE_DOMAIN=qa.example.com
BETTER_AUTH_TRUSTED_ORIGINS=https://app.qa.example.com,https://zero.qa.example.com
ZERO_CACHE_URL=https://zero.qa.example.com

# --- Migrations ---
RUN_MIGRATIONS=true

# --- zero-cache (required) ---
ZERO_ADMIN_PASSWORD=replace-with-a-strong-qa-zero-admin-password
ZERO_LOG_LEVEL=info

# --- zero-cache defaults (usually leave as-is) ---
ZERO_REPLICA_FILE=/data/replica.db
ZERO_QUERY_URL=http://app:3000/api/zero/query
ZERO_MUTATE_URL=http://app:3000/api/zero/mutate
ZERO_QUERY_FORWARD_COOKIES=true
ZERO_MUTATE_FORWARD_COOKIES=true
ZERO_ENABLE_CRUD_MUTATIONS=false
ZERO_APP_ID=zentro-qa
