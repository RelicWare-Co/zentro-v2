# Copy to deploy/.env.production for plain `docker compose` deploys.
# On Coolify, set these in the resource Environment Variables UI instead.
# Do not commit deploy/.env.production.

# --- Host ports (plain docker compose only) ---
APP_PORT=3000
ZERO_PORT=4848

# --- External Postgres (direct connection, wal_level=logical) ---
DATABASE_URL=postgresql://user:password@db.example.com:5432/zentro

# --- App / auth (public browser-facing URLs) ---
# Coolify: assign domains to app:3000 and zero-cache:4848, then set e.g.
#   BETTER_AUTH_URL=${SERVICE_URL_APP}
#   ZERO_CACHE_URL=${SERVICE_URL_ZERO-CACHE}
#   BETTER_AUTH_TRUSTED_ORIGINS=${SERVICE_URL_APP},${SERVICE_URL_ZERO-CACHE}
BETTER_AUTH_URL=https://app.example.com
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_COOKIE_DOMAIN=example.com
BETTER_AUTH_TRUSTED_ORIGINS=https://app.example.com,https://zero.example.com
ZERO_CACHE_URL=https://zero.example.com

# --- Migrations ---
RUN_MIGRATIONS=true

# --- zero-cache (required in production) ---
ZERO_ADMIN_PASSWORD=replace-with-a-strong-secret
ZERO_LOG_LEVEL=info

# --- zero-cache defaults (usually leave as-is) ---
ZERO_REPLICA_FILE=/data/replica.db
ZERO_QUERY_URL=http://app:3000/api/zero/query
ZERO_MUTATE_URL=http://app:3000/api/zero/mutate
ZERO_QUERY_FORWARD_COOKIES=true
ZERO_MUTATE_FORWARD_COOKIES=true
ZERO_ENABLE_CRUD_MUTATIONS=false
ZERO_APP_ID=zentro
