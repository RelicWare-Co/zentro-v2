# Copy to deploy/.env.production and fill in real values.
# Do not commit deploy/.env.production.
#
# Deploy:
#   docker compose -f deploy/docker-compose.prod.yml --env-file deploy/.env.production up -d --build

# --- Host ports (optional) ---
APP_PORT=3000
ZERO_PORT=4848

# --- External Postgres (direct connection, wal_level=logical) ---
DATABASE_URL=postgresql://user:password@db.example.com:5432/zentro

# --- App / auth (public browser-facing URLs) ---
BETTER_AUTH_URL=https://app.example.com
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_COOKIE_DOMAIN=example.com
BETTER_AUTH_TRUSTED_ORIGINS=https://app.example.com,https://zero.example.com
ZERO_CACHE_URL=https://zero.example.com

# --- Migrations ---
RUN_MIGRATIONS=true

# --- zero-cache (required in production) ---
ZERO_ADMIN_PASSWORD=replace-with-a-strong-secret
ZERO_LOG_LEVEL=info
