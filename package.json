    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "^0.3.1",
    "drizzle-zero": "^0.18.0",
    "lefthook": "^2.1.9",
    "node-gyp": "^13.0.0",
    "postcss": "^8.5.15",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3",
    "vite": "^8.0.16"
  },
  "scripts": {
    "dev": "vike dev",
    "dev:docker": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "dev:docker:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "dev:docker:install": "docker compose -f docker-compose.yml -f docker-compose.dev.yml run --rm app bun install",
    "dev:docker:reset": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down -v && docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build -V",
    "docker:publish": "./scripts/publish-ghcr.sh",
    "build": "vike build",
    "start": "bun ./dist/server/index.mjs",
    "preview": "vike build && vike preview",
    "desktop:dev": "bun run --cwd desktop dev",
    "desktop:package": "bun run --cwd desktop package",
    "desktop:make": "bun run --cwd desktop make",
    "desktop:make:msix": "bun run --cwd desktop make:msix",
    "desktop:make:win": "bun run --cwd desktop make:win",
    "desktop:check": "bun run --cwd desktop check",
    "desktop:fix": "bun run --cwd desktop fix",
    "test": "bun test tests/*.test.ts",
    "e2e:playwright": "playwright test",
    "e2e:playwright:smoke": "playwright test --grep @smoke",
    "e2e:playwright:ui": "playwright test --ui",
    "e2e:playwright:debug": "playwright test --debug",
    "e2e:playwright:report": "playwright show-report",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun ./scripts/migrate.ts",
    "db:seed": "bun ./scripts/seed-products.ts",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "zero:schema:gen": "drizzle-zero generate --output zero/schema.gen.ts --format",
    "zero:dev": "zero-cache-dev",
    "prod": "bun run build && bun run start",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "git:fix-eol": "bun ./scripts/fix-git-eol.mjs",
    "prepare": "bun ./scripts/install-lefthook.mjs",
    "doctor": "npx react-doctor@latest"
  },
  "trustedDependencies": [
    "@rocicorp/zero-sqlite3"
  ],
  "type": "module"
}
