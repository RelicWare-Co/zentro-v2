{
  "compilerOptions": {
    "allowJs": false,
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": [
    "forge.config.ts",
    "forge.env.d.ts",
    "vite.*.config.ts",
    "src/**/*.ts"
  ]
}
