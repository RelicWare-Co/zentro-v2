{
  "compilerOptions": {
    "allowJs": false,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["../*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2022",
    "types": ["vite/client", "node"]
  },
  "include": [
    "forge.config.ts",
    "forge.msix.ts",
    "forge.env.d.ts",
    "vite.*.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "../types/**/*.d.ts"
  ]
}
