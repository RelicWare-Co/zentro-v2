# Variables solo para empaquetado MSIX en Windows (no afectan desktop:dev).

# Identidad del paquete (obligatorio para Store; opcional en sideload con manifest generado).
# Publisher debe coincidir EXACTAMENTE con Partner Center (incluye prefijo CN=).
ZENTRO_MSIX_PUBLISHER="CN=YOUR_PUBLISHER_FROM_PARTNER_CENTER"
ZENTRO_MSIX_PACKAGE_IDENTITY="00000000-0000-0000-0000-000000000000"

# Ruta a Package.appxmanifest personalizado (opcional). Si no existe, Forge genera el manifest.
# ZENTRO_MSIX_APP_MANIFEST=./msix/Package.appxmanifest

# Windows Kit usado por electron-windows-msix. Debe existir en:
# C:\Program Files (x86)\Windows Kits\10\bin\<version>\x64
ZENTRO_MSIX_WINDOWS_KIT_VERSION="10.0.26100.0"

# Firma local (opcional). Para Microsoft Store puedes omitirla; Partner Center firma al publicar.
# ZENTRO_MSIX_SIGN=true
# ZENTRO_MSIX_CERT_FILE=C:\path\to\devcert.pfx
# ZENTRO_MSIX_CERT_PASSWORD=

# Depuración del maker MSIX
# DEBUG=electron-windows-msix*
